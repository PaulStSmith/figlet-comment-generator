{
  "name": "figlet",
  "displayName": "FIGlet Comment Generator",
  "description": "Create beautiful ASCII art comments in your code using FIGlet fonts",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.95.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "figlet.insertBanner",
        "title": "Generate FIGlet Banner"
      },
      {
        "command": "figlet.selectFontDirectory",
        "title": "Select Font Directory",
        "category": "FIGlet Comments",
        "icon": "${folder}"
      },
      {
        "command": "figlet.selectDefaultFont",
        "title": "Select Default Font",
        "category": "FIGlet Comments"
      },
      {
        "command": "figlet.inspectConfig",
        "title": "Inspect FIGlet Configuration"
      },
      {
        "command": "figlet.openSettings",
        "title": "FIGlet Settings",
        "category": "FIGlet Comments"
      }
    ],
    "keybindings": [
      {
        "command": "figlet.insertBanner",
        "key": "ctrl+shift+f",
        "mac": "cmd+shift+f",
        "when": "editorTextFocus"
      }
    ],
    "configuration": {
      "title": "FIGlet Comments",
      "properties": {
        "figlet.fontDirectory": {
          "type": "string",
          "default": "",
          "description": "Directory containing FIGlet font files (.flf)",
          "markdownDescription": "Directory containing FIGlet font files (.flf). [Browse...](command:figlet.selectFontDirectory)"
        },
        "figlet.defaultFont": {
          "type": "string",
          "default": "small",
          "description": "Default FIGlet font to use",
          "markdownDescription": "Default FIGlet font to use. [Select Font...](command:figlet.selectDefaultFont)"
        },
        "figlet.layoutMode": {
          "type": "string",
          "enum": [
            "full",
            "kerning",
            "smush"
          ],
          "enumDescriptions": [
            "Full Size: characters are placed side-by-side with no overlap",
            "Kerning: characters are moved together until they touch",
            "Smushing: characters are merged using font smushing rules"
          ],
          "default": "smush",
          "description": "Layout mode for FIGlet text rendering"
        }
      }
    }
  },
  "files": [
    "out/**/*",
    "media/**/*",
    "resources/**/*"
  ],
  "scripts": {
    "vscode:prepublish": "npm run compile && npm run build:webview",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "build:webview": "webpack --config webpack.config.js",
    "watch:webview": "webpack --config webpack.config.js --watch",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.9",
    "@types/node": "20.x",
    "@types/react-dom": "^18.3.1",
    "@types/vscode": "^1.95.0",
    "@typescript-eslint/eslint-plugin": "^8.10.0",
    "@typescript-eslint/parser": "^8.7.0",
    "@vscode/test-cli": "^0.0.10",
    "@vscode/test-electron": "^2.4.1",
    "eslint": "^9.13.0",
    "ts-loader": "^9.5.1",
    "typescript": "^5.6.3",
    "webpack": "^5.96.1",
    "webpack-cli": "^5.1.4"
  },
  "dependencies": {
    "@types/react": "^18.3.12",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  }
}
