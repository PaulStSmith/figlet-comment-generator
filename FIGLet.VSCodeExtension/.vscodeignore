# Source & build inputs — not needed at runtime
src/**
**/tsconfig.json
**/eslint.config.mjs
**/eslint.config.js
webpack.config.js

# Test infrastructure
.vscode-test/**
**/.vscode-test.*

# Editor / IDE
.vscode/**

# Package management
node_modules/**
package-lock.json
.yarnrc

# VCS
.gitignore
.gitattributes

# Documentation & misc (README.md is intentionally kept — Marketplace requires it)
CONTRIBUTING.md
CHANGELOG.md
vsc-extension-quickstart.md

# Media — screenshot and icon PNGs are intentionally kept; Marketplace renders them from README.md
# media/screenshot.png        ← kept
# media/screenshot-settings.png ← kept
# media/icon.png               ← kept
media/*.js.LICENSE.txt

# Type-only files already compiled into out/
**/*.ts

# Source maps (optional: remove this line to include them for debugging)
**/*.map
